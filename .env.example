# Porta do dev server
PORT=3000

# Base da API (vazio = usa /api relativo, servido pelas rotas mock em server/api/*)
NUXT_PUBLIC_API_BASE=

# Origem das imagens dos profissionais mock
# local = fotos curadas em public/images/professionals (padrão)
# faker = imagens geradas via faker/picsum.photos (só para testes locais)
NUXT_PUBLIC_IMAGE_SOURCE=local
